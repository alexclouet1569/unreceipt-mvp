# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service-role key — SERVER ONLY. Never NEXT_PUBLIC_, never imported
# from a "use client" file. Used by /api/webhooks/stripe and /api/admin/*.
# Found in Supabase Dashboard → Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Comma-separated allowlist of founder emails who can access /admin and
# /api/admin/*. Case-insensitive, surrounding whitespace tolerated.
# Example: alexandre@unreceipt.com,alex@example.com
CONCIERGE_ADMIN_EMAILS=

# Resend (for welcome emails)
RESEND_API_KEY=re_your-api-key-here

# Stripe (REQUIRED — all four)
# Server-side only:
STRIPE_SECRET_KEY=sk_test_or_sk_live_here
# whsec_ from `stripe listen` locally; from the Webhooks endpoint config in the
# Stripe Dashboard for prod. The local and prod values are different secrets.
STRIPE_WEBHOOK_SECRET=whsec_here
# The Price ID for the €49/mo recurring subscription. Stripe Dashboard →
# Products → UnReceipt Concierge → copy the price_... id.
STRIPE_PRICE_ID=price_here
# Browser-safe — used by future Stripe.js Elements work, not by Checkout itself.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_or_pk_live_here
